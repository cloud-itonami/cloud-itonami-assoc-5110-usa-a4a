(ns association-facts
  (:export [main association-covered? entry-count entry-field topic-count
            topic by-topic-count by-topic-id coverage-note]))

(defn association-covered? [association :string] :i64 (string=? association "a4a"))
(defn entry-count [association :string] :i64 (if (association-covered? association) 2 0))
(defn valid-entry? [association :string index :i64] :i64
  (if (association-covered? association) (if (= index 0) 1 (if (= index 1) 1 0)) 0))

(defn entry-field [association :string index :i64 field :string] [:option :string]
  (if (valid-entry? association index)
    (if (= index 0)
      (cond
        (string=? field "id") (option-some-of [:option :string] "a4a.spec-2000")
        (string=? field "title") (option-some-of [:option :string] "Spec 2000: Data Exchange Standards")
        (string=? field "association") (option-some-of [:option :string] "a4a")
        (string=? field "isic") (option-some-of [:option :string] "5110")
        (string=? field "country") (option-some-of [:option :string] "USA")
        (string=? field "kind") (option-some-of [:option :string] "technical-standard")
        (string=? field "url") (option-some-of [:option :string] "https://ataebiz.org/spec-2000/")
        (string=? field "url-provenance") (option-some-of [:option :string] "official-association-site")
        (string=? field "retrieved-at") (option-some-of [:option :string] "2026-07-15")
        :else (option-none-of [:option :string]))
      (cond
        (string=? field "id") (option-some-of [:option :string] "a4a.history-profile")
        (string=? field "title") (option-some-of [:option :string] "History (organization profile)")
        (string=? field "association") (option-some-of [:option :string] "a4a")
        (string=? field "isic") (option-some-of [:option :string] "5110")
        (string=? field "country") (option-some-of [:option :string] "USA")
        (string=? field "kind") (option-some-of [:option :string] "governance-program")
        (string=? field "url") (option-some-of [:option :string] "https://www.airlines.org/who-we-are/history/")
        (string=? field "url-provenance") (option-some-of [:option :string] "official-association-site")
        (string=? field "established-date") (option-some-of [:option :string] "1936")
        (string=? field "retrieved-at") (option-some-of [:option :string] "2026-07-15")
        :else (option-none-of [:option :string])))
    (option-none-of [:option :string])))

(defn topic-count [association :string index :i64] :i64
  (if (valid-entry? association index) (if (= index 0) 2 1) 0))
(defn topic [association :string index :i64 topic-index :i64] [:option :string]
  (if (valid-entry? association index)
    (if (= index 0)
      (if (= topic-index 0) (option-some-of [:option :string] "interoperability")
          (if (= topic-index 1) (option-some-of [:option :string] "standards") (option-none-of [:option :string])))
      (if (= topic-index 0) (option-some-of [:option :string] "governance") (option-none-of [:option :string])))
    (option-none-of [:option :string])))
(defn by-topic-count [association :string candidate :string] :i64
  (if (association-covered? association)
    (if (string=? candidate "interoperability") 1
        (if (string=? candidate "standards") 1 (if (string=? candidate "governance") 1 0))) 0))
(defn by-topic-id [association :string candidate :string index :i64] [:option :string]
  (if (association-covered? association)
    (if (= index 0)
      (if (string=? candidate "interoperability") (entry-field association 0 "id")
          (if (string=? candidate "standards") (entry-field association 0 "id")
              (if (string=? candidate "governance") (entry-field association 1 "id") (option-none-of [:option :string]))))
      (option-none-of [:option :string]))
    (option-none-of [:option :string])))
(defn coverage-note [association :string] [:option :string]
  (if (association-covered? association)
    (option-some-of [:option :string] "cloud-itonami-assoc-5110-usa-a4a Wave 0 (ADR-2607141700): 2 a4a entries seeded with official airlines.org/ataebiz.org citations. Extend the sovereign catalog; never fabricate a rule id/url.")
    (option-none-of [:option :string])))
(defn main [] :i64 0)
